# Forzar LF en todos los archivos por defecto
* text=auto

# Scripts de shell SIEMPRE deben usar LF (Unix), nunca CRLF (Windows)
*.sh text eol=lf

# Archivos de configuracion en texto plano
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Archivos binarios - sin conversión
*.zip binary
*.png binary
*.jpg binary
*.pdf binary

# Excluir del ZIP (git archive export-ignore)
INFORME_PENTESTING.md export-ignore
test_sprint2.py export-ignore
tests/ export-ignore
.coverage export-ignore
